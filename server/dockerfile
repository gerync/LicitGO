ARG NODE_VERSION=24.10.0

FROM node:${NODE_VERSION}-alpine AS builder

ENV NODE_ENV=production

WORKDIR /usr/src/app

COPY package*.json ./
RUN npm i --omit=dev

COPY .env /usr/src/app/.env
COPY . /usr/src/app

# Ensure media and exchange directories exist and are writable by the non-root `node` user
RUN mkdir -p /usr/src/app/media/cars \
	&& mkdir -p /usr/src/app/src/utilities/exchange \
	&& [ -f /usr/src/app/src/utilities/exchange/exchangeRates.json ] || echo '[]' > /usr/src/app/src/utilities/exchange/exchangeRates.json \
	&& chown -R node:node /usr/src/app/media \
	&& chown -R node:node /usr/src/app/src/utilities/exchange \
	&& chmod -R u+rwX,g+rwX,o+rX /usr/src/app/media \
	&& chmod -R u+rwX,g+rwX,o+rX /usr/src/app/src/utilities/exchange

USER node

EXPOSE 15000

ENV NODE_OPTIONS=--experimental-specifier-resolution=node
CMD ["node", "./src/server.js"]